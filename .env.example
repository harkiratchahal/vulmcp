# Database connection (PostgreSQL via Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis connection (Upstash, Redis Cloud, etc.)
REDIS_URL=rediss://default:password@host:6379

# App settings
APP_NAME=VulnixMCP
DEBUG=false

# NVD API Key (free from https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=your-nvd-api-key-here

# Anthropic API Key (for attack chain analysis)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Scan settings
SCAN_TIMEOUT=600
MAX_CONCURRENT_SCANS=3
LOG_LEVEL=INFO

# Server port (used in cloud deployments)
PORT=8000
