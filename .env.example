# Neon PostgreSQL (get from console.neon.tech)
DATABASE_URL=postgresql+psycopg2://user:pass@host/dbname?sslmode=require

# Upstash Redis (get from console.upstash.com)
REDIS_URL=rediss://:password@host:port

# NVD API key (get from nvd.nist.gov/developers/request-an-api-key — free)
NVD_API_KEY=your-nvd-api-key

# App settings
SCAN_TIMEOUT=600          # max scan duration in seconds
MAX_CONCURRENT_SCANS=3
LOG_LEVEL=INFO
